[08-Jul-2022 10:32:58 UTC] WordPress database error Duplicate entry '1509' for key 'PRIMARY' for query INSERT INTO `ob_posts` (`post_author`, `post_date`, `post_date_gmt`, `post_content`, `post_content_filtered`, `post_title`, `post_excerpt`, `post_status`, `post_type`, `comment_status`, `ping_status`, `post_password`, `post_name`, `to_ping`, `pinged`, `post_modified`, `post_modified_gmt`, `post_parent`, `menu_order`, `post_mime_type`, `guid`, `ID`) VALUES (1, '2022-03-23 03:06:11', '2022-03-23 03:06:11', '<!-- wp:paragraph -->\n<p>काठमाडौं । मंगलबार नेकपा एमालेमा प्रवेश गरेकी अभिनेत्री करिश्मा मानन्धरले मुख्य तीन कारणले आफू पार्टी प्रवेश गरेको बताएकी छन् । पार्टी प्रवेश गर्नुको पहिलो कारणको रुपमा उनले अध्यक्ष केपी शर्मा ओलीलाई कारण देखाइन् ।</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:image {\"id\":1508,\"sizeSlug\":\"large\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image size-large\"><img src=\"https://onlinebansgadhi.com/wp-content/uploads/2022/03/img_7942.jpg\" alt=\"\" class=\"wp-image-1508\"/></figure>\n<!-- /wp:image -->\n\n<!-- wp:paragraph -->\n<p>‘ओलीजीलाई फुर्काउन भनेकी होइन । नेता भनेको जनताको पथप्रदर्शक हो । ओलीमा त्यो प्रतिबद्धता र कुशलता पाउँछु । ओलीको इनर्जी देखेर ताजुब भएकी छु,’ पार्टी प्रवेश कार्यक्रममा बोल्दै उनले भनिन् ।</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:paragraph -->\n<p>एमालेले मुलुकको परिवर्तन र समृद्धिको सही एजेन्डा बोकेकाले आफूले पार्टी प्रवेश गर्ने निर्णय लिएको उनले बताइन् । तेस्रो कारणमा अधिकांश नेपाली नागरिकले एमालेसँग सद्भाव राख्ने भन्दै उनले यो पार्टी रोजेको बताइन् ।</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:paragraph -->\n<p>करिश्माले अगाडि भनिन्, ‘अब एमालेमा रहेर राजनीतिमा अघि बढ्ने अठोट गरेकी छु । यही अठोट लिएर मुलुकको समृद्धिको दिशामा अघि बढ्छु ।’ आफू नितान्त एमालेको कार्यकर्ता भएर कार्यकर्तासँग जोडिन आइपुगेको उनले बताइन् ।</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:paragraph -->\n<p>भागबण्डा र कुनै पदको लोभ लिएर आफू एमालेमा नआएको दाबी गर्दै उनले पार्टीमा दिइने जिम्मेवारीबाट पछि नहट्ने बताइन् । ‘पार्टीमा कुनै जिम्मा दिइन